{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "backend_engine/**"
    ],
    "buildCommand": "cd backend_engine && npm install"
  },
  "deploy": {
    "startCommand": "cd backend_engine && npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
